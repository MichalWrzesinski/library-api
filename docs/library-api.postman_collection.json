{
    "info": {
        "name": "Library API",
        "description": "Postman collection for testing only the required library task functionality.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8080"
        },
        {
            "key": "authorId",
            "value": "1"
        },
        {
            "key": "authorIri",
            "value": "/api/authors/1"
        },
        {
            "key": "bookId",
            "value": "1"
        },
        {
            "key": "bookIri",
            "value": "/api/books/1"
        },
        {
            "key": "serialNumber",
            "value": "123456"
        }
    ],
    "item": [
        {
            "name": "Create author",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/ld+json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/ld+json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Robert C. Martin\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/authors",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "authors"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Author created', function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "const response = pm.response.json();",
                            "pm.collectionVariables.set('authorId', response.id);",
                            "pm.collectionVariables.set('authorIri', response['@id']);"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Add book",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/ld+json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/ld+json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"serialNumber\": \"{{serialNumber}}\",\n  \"title\": \"Clean Code\",\n  \"author\": \"{{authorIri}}\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/books",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Book created', function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "",
                            "const response = pm.response.json();",
                            "pm.collectionVariables.set('bookId', response.id);",
                            "pm.collectionVariables.set('bookIri', response['@id']);"
                        ]
                    }
                }
            ]
        },
        {
            "name": "List books",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/ld+json"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/books",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Books listed', function () {",
                            "    pm.response.to.have.status(200);",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Update book",
            "request": {
                "method": "PATCH",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/merge-patch+json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/ld+json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"title\": \"Clean Code Updated\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/books/{{bookId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books",
                        "{{bookId}}"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Book updated', function () {",
                            "    pm.response.to.have.status(200);",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Borrow book",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"borrowerCardNumber\": \"654321\",\n  \"expectedReturnAt\": \"2026-07-25T00:00:00+00:00\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{baseUrl}}/api/books/{{bookId}}/borrow",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books",
                        "{{bookId}}",
                        "borrow"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Book borrowed', function () {",
                            "    pm.response.to.have.status(201);",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Return book",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ],
                "url": {
                    "raw": "{{baseUrl}}/api/books/{{bookId}}/return",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books",
                        "{{bookId}}",
                        "return"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Book returned', function () {",
                            "    pm.response.to.have.status(200);",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Delete book",
            "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/books/{{bookId}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "books",
                        "{{bookId}}"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('Book delete endpoint works', function () {",
                            "    pm.expect(pm.response.code).to.be.oneOf([204, 409, 500]);",
                            "});"
                        ]
                    }
                }
            ]
        }
    ]
}
